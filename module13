<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Patient Health Monitoring Dashboard</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#00c6ff,#0072ff);
}

.container{
    width:90%;
    max-width:850px;
    background:white;
    padding:30px;
    border-radius:15px;
    box-shadow:0 10px 25px rgba(0,0,0,0.25);
}

h1{
    text-align:center;
    color:#333;
    margin-bottom:25px;
}

.dashboard{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
    gap:20px;
}

.card{
    padding:25px;
    background:#f5f5f5;
    border-radius:12px;
    text-align:center;
}

.icon{
    font-size:45px;
}

.value{
    font-size:32px;
    font-weight:bold;
    margin:15px 0;
    color:#007bff;
}

.label{
    font-size:18px;
    color:#555;
}

.status{
    margin-top:25px;
    padding:15px;
    border-radius:10px;
    text-align:center;
    font-size:22px;
    font-weight:bold;
}

.normal{
    background:#28a745;
    color:white;
}

.warning{
    background:#ffc107;
    color:black;
}

.danger{
    background:#dc3545;
    color:white;
}

.footer{
    text-align:center;
    margin-top:20px;
    color:#777;
}

</style>

</head>

<body>

<div class="container">

<h1>❤️ Patient Health Monitoring</h1>


<div class="dashboard">

<div class="card">
    <div class="icon">❤️</div>
    <div class="value" id="heart">75 BPM</div>
    <div class="label">Heart Rate</div>
</div>


<div class="card">
    <div class="icon">🫁</div>
    <div class="value" id="spo2">98%</div>
    <div class="label">SpO₂ Level</div>
</div>


<div class="card">
    <div class="icon">🌡</div>
    <div class="value" id="temp">36.5°C</div>
    <div class="label">Body Temperature</div>
</div>

</div>


<div class="status normal" id="healthStatus">
    🟢 Patient Condition Normal
</div>


<div class="footer">
    Last Updated:
    <span id="time"></span>
</div>


</div>


<script>


function updateHealth(){

    // Replace with real sensor data
    let heart = Math.floor(60 + Math.random()*50);
    let spo2 = Math.floor(90 + Math.random()*10);
    let temp = (36 + Math.random()*2).toFixed(1);


    document.getElementById("heart").innerHTML =
        heart + " BPM";

    document.getElementById("spo2").innerHTML =
        spo2 + "%";

    document.getElementById("temp").innerHTML =
        temp + " °C";


    let status=document.getElementById("healthStatus");


    if(heart > 120 || spo2 < 92 || temp > 38){

        status.innerHTML =
        "🔴 Critical Condition";

        status.className="status danger";

    }

    else if(heart > 100 || spo2 < 95 || temp > 37.5){

        status.innerHTML =
        "🟡 Monitor Patient";

        status.className="status warning";

    }

    else{

        status.innerHTML =
        "🟢 Patient Condition Normal";

        status.className="status normal";

    }


    document.getElementById("time").innerHTML =
        new Date().toLocaleTimeString();

}


updateHealth();

setInterval(updateHealth,2000);


</script>

</body>
</html>