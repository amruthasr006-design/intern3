<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Home Automation Dashboard</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family:Arial, Helvetica, sans-serif;
    }

    body{
        background:#eef2f7;
        display:flex;
        justify-content:center;
        align-items:center;
        min-height:100vh;
    }

    .dashboard{
        width:800px;
        background:#fff;
        padding:25px;
        border-radius:15px;
        box-shadow:0 5px 15px rgba(0,0,0,0.2);
    }

    h1{
        text-align:center;
        color:#333;
        margin-bottom:20px;
    }

    .section{
        margin-bottom:25px;
    }

    .section h2{
        color:#444;
        margin-bottom:10px;
        border-bottom:2px solid #ddd;
        padding-bottom:5px;
    }

    .device{
        display:flex;
        justify-content:space-between;
        align-items:center;
        background:#f7f7f7;
        padding:12px;
        margin:10px 0;
        border-radius:8px;
    }

    .device-name{
        font-size:18px;
    }

    button{
        padding:8px 18px;
        border:none;
        border-radius:5px;
        color:#fff;
        cursor:pointer;
        font-size:15px;
    }

    .on{
        background:green;
    }

    .off{
        background:red;
    }

    .footer{
        text-align:center;
        margin-top:20px;
    }

    .footer button{
        background:#007BFF;
        margin:5px;
    }
</style>
</head>

<body>

<div class="dashboard">

<h1>🏠 Home Automation Dashboard</h1>

<div class="section">
<h2>💡 Lights</h2>

<div class="device">
<span class="device-name">Living Room Light</span>
<button class="off" onclick="toggle(this)">OFF</button>
</div>

<div class="device">
<span class="device-name">Bedroom Light</span>
<button class="off" onclick="toggle(this)">OFF</button>
</div>

</div>

<div class="section">
<h2>🌀 Fans</h2>

<div class="device">
<span class="device-name">Hall Fan</span>
<button class="off" onclick="toggle(this)">OFF</button>
</div>

<div class="device">
<span class="device-name">Bedroom Fan</span>
<button class="off" onclick="toggle(this)">OFF</button>
</div>

</div>

<div class="section">
<h2>🔌 Appliances</h2>

<div class="device">
<span class="device-name">Television</span>
<button class="off" onclick="toggle(this)">OFF</button>
</div>

<div class="device">
<span class="device-name">Air Conditioner</span>
<button class="off" onclick="toggle(this)">OFF</button>
</div>

<div class="device">
<span class="device-name">Washing Machine</span>
<button class="off" onclick="toggle(this)">OFF</button>
</div>

</div>

<div class="footer">
<button>Schedule</button>
<button>Energy Report</button>
<button>Logout</button>
</div>

</div>

<script>
function toggle(btn){
    if(btn.innerHTML=="OFF"){
        btn.innerHTML="ON";
        btn.classList.remove("off");
        btn.classList.add("on");
    }else{
        btn.innerHTML="OFF";
        btn.classList.remove("on");
        btn.classList.add("off");
    }
}
</script>

</body>
</html>