<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Irrigation Dashboard</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:linear-gradient(135deg,#43cea2,#185a9d);
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
}

.container{
    background:#fff;
    width:380px;
    padding:30px;
    border-radius:15px;
    text-align:center;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
}

h1{
    color:#333;
    margin-bottom:20px;
}

.card{
    background:#f5f5f5;
    padding:20px;
    border-radius:10px;
    margin:15px 0;
}

.value{
    font-size:35px;
    color:#2196F3;
    font-weight:bold;
    margin:10px 0;
}

.progress{
    width:100%;
    height:25px;
    background:#ddd;
    border-radius:20px;
    overflow:hidden;
}

.progress-bar{
    height:100%;
    width:0%;
    background:#4CAF50;
    color:white;
    line-height:25px;
    font-weight:bold;
    transition:0.5s;
}

button{
    margin-top:20px;
    width:100%;
    padding:12px;
    font-size:18px;
    border:none;
    border-radius:8px;
    cursor:pointer;
    background:#28a745;
    color:white;
}

button:hover{
    opacity:0.9;
}

.status{
    margin-top:15px;
    font-size:18px;
    font-weight:bold;
}

.footer{
    margin-top:20px;
    color:#666;
}
</style>
</head>

<body>

<div class="container">

<h1>🌱 Smart Irrigation Dashboard</h1>

<div class="card">
    <h3>Soil Moisture</h3>

    <div class="value" id="moisture">0%</div>

    <div class="progress">
        <div class="progress-bar" id="bar">0%</div>
    </div>
</div>

<div class="card">
    <h3>Water Pump</h3>
    <button onclick="togglePump()" id="pumpBtn">Turn ON</button>
    <div class="status" id="pumpStatus">Pump OFF</div>
</div>

<div class="footer">
    Last Updated:
    <span id="time"></span>
</div>

</div>

<script>

let pump = false;

function updateDashboard(){

    // Replace with actual sensor value
    let moisture = Math.floor(Math.random()*101);

    document.getElementById("moisture").innerHTML = moisture + "%";

    document.getElementById("bar").style.width = moisture + "%";
    document.getElementById("bar").innerHTML = moisture + "%";

    if(moisture < 30){
        document.getElementById("bar").style.background="#dc3545";
    }
    else if(moisture < 70){
        document.getElementById("bar").style.background="#ffc107";
    }
    else{
        document.getElementById("bar").style.background="#28a745";
    }

    document.getElementById("time").innerHTML =
        new Date().toLocaleTimeString();
}

function togglePump(){

    pump = !pump;

    if(pump){
        document.getElementById("pumpStatus").innerHTML = "🟢 Pump ON";
        document.getElementById("pumpBtn").innerHTML = "Turn OFF";
        document.getElementById("pumpBtn").style.background = "#dc3545";
    }
    else{
        document.getElementById("pumpStatus").innerHTML = "🔴 Pump OFF";
        document.getElementById("pumpBtn").innerHTML = "Turn ON";
        document.getElementById("pumpBtn").style.background = "#28a745";
    }

    // Send pump status to ESP32 (example)
    /*
    fetch("/pump?state=" + (pump ? "on" : "off"));
    */
}

updateDashboard();
setInterval(updateDashboard,2000);

</script>

</body>
</html>