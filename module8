<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Energy Monitoring</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:linear-gradient(135deg,#232526,#414345);
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
}

.container{
    width:90%;
    max-width:800px;
    background:white;
    padding:30px;
    border-radius:15px;
    box-shadow:0 10px 25px rgba(0,0,0,0.3);
}

h1{
    text-align:center;
    color:#333;
    margin-bottom:25px;
}

.dashboard{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(170px,1fr));
    gap:20px;
}

.card{
    background:#f5f5f5;
    padding:25px;
    border-radius:12px;
    text-align:center;
}

.icon{
    font-size:40px;
}

.value{
    font-size:30px;
    font-weight:bold;
    color:#007bff;
    margin:12px 0;
}

.label{
    font-size:17px;
    color:#555;
}

.status{
    margin-top:25px;
    text-align:center;
    font-size:20px;
    font-weight:bold;
}

.footer{
    text-align:center;
    margin-top:20px;
    color:#777;
}
</style>

</head>

<body>

<div class="container">

<h1>⚡ Smart Energy Monitoring</h1>

<div class="dashboard">

<div class="card">
    <div class="icon">🔌</div>
    <div class="value" id="voltage">230 V</div>
    <div class="label">Voltage</div>
</div>

<div class="card">
    <div class="icon">🔋</div>
    <div class="value" id="current">2.5 A</div>
    <div class="label">Current</div>
</div>

<div class="card">
    <div class="icon">⚡</div>
    <div class="value" id="power">575 W</div>
    <div class="label">Power</div>
</div>

<div class="card">
    <div class="icon">📈</div>
    <div class="value" id="energy">4.8 kWh</div>
    <div class="label">Energy Usage</div>
</div>

</div>

<div class="status" id="status">
    🟢 System Normal
</div>

<div class="footer">
    Last Updated: <span id="time"></span>
</div>

</div>


<script>

function updateEnergy(){

    // Replace with actual sensor readings
    let voltage = (220 + Math.random()*20).toFixed(1);
    let current = (1 + Math.random()*5).toFixed(2);
    let power = (voltage * current).toFixed(1);
    let energy = (Math.random()*10).toFixed(2);

    document.getElementById("voltage").innerHTML =
        voltage + " V";

    document.getElementById("current").innerHTML =
        current + " A";

    document.getElementById("power").innerHTML =
        power + " W";

    document.getElementById("energy").innerHTML =
        energy + " kWh";


    let status=document.getElementById("status");

    if(power > 1000){
        status.innerHTML="🔴 High Power Consumption";
        status.style.color="red";
    }
    else{
        status.innerHTML="🟢 System Normal";
        status.style.color="green";
    }


    document.getElementById("time").innerHTML =
        new Date().toLocaleTimeString();

}


updateEnergy();
setInterval(updateEnergy,2000);

</script>

</body>
</html>