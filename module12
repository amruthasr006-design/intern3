<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GPS Vehicle Tracking Dashboard</title>

<!-- Leaflet Map Library -->
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:linear-gradient(135deg,#2193b0,#6dd5ed);
    min-height:100vh;
    padding:20px;
}

.container{
    max-width:900px;
    margin:auto;
    background:white;
    padding:25px;
    border-radius:15px;
    box-shadow:0 10px 25px rgba(0,0,0,0.25);
}

h1{
    text-align:center;
    color:#333;
    margin-bottom:20px;
}

.info{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
    gap:15px;
    margin-bottom:20px;
}

.card{
    background:#f4f4f4;
    padding:15px;
    border-radius:10px;
    text-align:center;
}

.value{
    font-size:24px;
    font-weight:bold;
    color:#007bff;
    margin-top:8px;
}

.label{
    color:#555;
}

#map{
    height:450px;
    width:100%;
    border-radius:12px;
}

.footer{
    text-align:center;
    margin-top:15px;
    color:#777;
}

</style>

</head>

<body>

<div class="container">

<h1>🚗 GPS Vehicle Tracking</h1>


<div class="info">

<div class="card">
    <div class="label">Latitude</div>
    <div class="value" id="lat">11.0168</div>
</div>

<div class="card">
    <div class="label">Longitude</div>
    <div class="value" id="lng">76.9558</div>
</div>

<div class="card">
    <div class="label">Vehicle Status</div>
    <div class="value" id="status">Moving</div>
</div>

</div>


<div id="map"></div>


<div class="footer">
    Last Updated:
    <span id="time"></span>
</div>


</div>


<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>

// Initial GPS location
let latitude = 11.0168;
let longitude = 76.9558;


// Create map
let map = L.map('map').setView(
    [latitude, longitude], 
    15
);


// Map tiles
L.tileLayer(
'https://tile.openstreetmap.org/{z}/{x}/{y}.png',
{
    attribution:'OpenStreetMap'
}
).addTo(map);


// Vehicle marker
let marker = L.marker(
    [latitude, longitude]
).addTo(map)
.bindPopup("🚗 Vehicle Location")
.openPopup();



function updateLocation(){

    // Replace with real GPS data from NEO-6M GPS module

    latitude += (Math.random()-0.5)*0.001;
    longitude += (Math.random()-0.5)*0.001;


    marker.setLatLng(
        [latitude,longitude]
    );

    map.setView(
        [latitude,longitude]
    );


    document.getElementById("lat").innerHTML =
        latitude.toFixed(6);

    document.getElementById("lng").innerHTML =
        longitude.toFixed(6);


    document.getElementById("time").innerHTML =
        new Date().toLocaleTimeString();

}


// Update every 5 seconds
setInterval(updateLocation,5000);

updateLocation();


</script>

</body>
</html>